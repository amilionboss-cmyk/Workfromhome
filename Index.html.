<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Redirecting...</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script>
    const links = [
      "https://singingfiles.com/show.php?l=0&u=2467240&id=72940",
      "https://doctoredits.com/show.php?l=0&u=2467240&id=74033",
      "https://ridefiles.net/show.php?l=0&u=2467240&id=73794",
      "https://singingfiles.com/show.php?l=0&u=2467240&id=72846"
    ];

    const lastLink = localStorage.getItem("lastRedirect");
    let availableLinks = links.filter(link => link !== lastLink);

    // If all links have been used, reset the list
    if (availableLinks.length === 0) {
      availableLinks = [...links];
    }

    const randomLink = availableLinks[Math.floor(Math.random() * availableLinks.length)];
    localStorage.setItem("lastRedirect", randomLink);
    window.location.href = randomLink;
  </script>
</head>
<body>
  <p>Redirecting you to the best available offer…</p>
</body>
</html>
